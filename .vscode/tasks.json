{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "reset-example-1",
			"command": "git fetch --all && git checkout 9f214^1",
			"options": {
				"cwd": "${workspaceFolder}/../navedit-extension-test-folder/stable-diffusion-webui"
			},
			"presentation": {
				"reveal": "silent",
				"revealProblems": "onProblem",
				"close": true
			}
		},
		{
			"type": "shell",
			"label": "reset-example-2",
			"command": "git fetch --all && git checkout 744e2ac^1",
			"options": {
				"cwd": "${workspaceFolder}/../navedit-extension-test-folder/models"
			},
			"presentation": {
				"reveal": "silent",
				"revealProblems": "onProblem",
				"close": true
			}
		},
		{
			"type": "shell",
			"label": "reset-example-3",
			"command": "git fetch --all && git checkout f3193^1",
			"options": {
				"cwd": "${workspaceFolder}/../navedit-extension-test-folder/keras"
			},
			"presentation": {
				"reveal": "silent",
				"revealProblems": "onProblem",
				"close": true
			}
		},
		{
			"type": "shell",
			"label": "reset-example-4",
			"command": "git fetch --all && git checkout 935e7^1",
			"options": {
				"cwd": "${workspaceFolder}/../navedit-extension-test-folder/scikit-learn"
			},
			"presentation": {
				"reveal": "silent",
				"revealProblems": "onProblem",
				"close": true
			}
		},
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": [{
				"base": "$tsc-watch",
    			"applyTo": "allDocuments",
				"fileLocation": ["relative", "${workspaceFolder}/extension"],
			}],
				
			"isBackground": true,
			"path": "extension",
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}