{
  "name": "trace-codephilia",
  "displayName": "CodeTRACE",
  "description": "A code co-edit helper.",
  "version": "0.1.1",
  "license": "MIT",
  "icon": "assets/TRACE-logo.png",
  "publisher": "CodePhilia",
  "engines": {
    "vscode": "^1.78.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:python",
    "onLanguage:go",
    "onLanguage:java"
  ],
  "main": "./out/extension",
  "contributes": {
    "configuration": [
      {
        "title": "TRACE",
        "properties": {
          "trace.queryURL": {
            "type": "string",
            "default": "http://localhost:5003",
            "description": "The backend URL to send query request to."
          },
          "trace.predictLocationOnEditAccept": {
            "type": "boolean",
            "default": "true",
            "description": "Perform another prediction immediately when accepting an edit."
          }
        }
      }
    ],
    "commands": [
      {
        "command": "trace.inputMessage",
        "category": "TRACE",
        "title": "Change Edit Description",
        "icon": "$(comment)"
      },
      {
        "title": "Last Suggestion",
        "category": "TRACE",
        "command": "trace.lastSuggestion",
        "icon": "$(arrow-left)",
        "enablement": "trace:hasPreviousSuggestion"
      },
      {
        "title": "Next Suggestion",
        "category": "TRACE",
        "command": "trace.nextSuggestion",
        "icon": "$(arrow-right)",
        "enablement": "trace:hasNextSuggestion"
      },
      {
        "title": "Accept",
        "category": "TRACE",
        "command": "trace.acceptEdit",
        "icon": "$(pass)"
      },
      {
        "title": "Dismiss",
        "category": "TRACE",
        "command": "trace.dismissEdit",
        "icon": "$(trash)"
      },
      {
        "title": "Predict Locations",
        "category": "TRACE",
        "command": "trace.predictLocations",
        "icon": "$(list-tree)"
      },
      {
        "title": "Generate Edits",
        "category": "TRACE",
        "command": "trace.generateEdits",
        "icon": "$(edit)"
      },
      {
        "title": "Show Commands",
        "command": "trace.showCommands"
      },
      {
        "title": "Clear Locations",
        "command": "trace.clearLocations",
        "icon": "$(close)"
      },
      {
        "title": "Clear Edit Memory",
        "command": "trace.clearPrevEdits",
        "icon": "$(history)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "trace.inputMessage",
          "group": "0_trace@3",
          "when": "editorFocus"
        },
        {
          "command": "trace.predictLocations",
          "group": "0_trace@1",
          "when": "editorFocus"
        },
        {
          "command": "trace.generateEdits",
          "group": "0_trace@2",
          "when": "editorFocus && trace:isLanguageSupported"
        }
      ],
      "editor/title": [
        {
          "command": "trace.lastSuggestion",
          "group": "navigation@-4",
          "when": "trace:isEditDiff"
        },
        {
          "command": "trace.nextSuggestion",
          "group": "navigation@-3",
          "when": "trace:isEditDiff"
        },
        {
          "command": "trace.acceptEdit",
          "group": "navigation@-2",
          "when": "trace:isEditDiff"
        },
        {
          "command": "trace.dismissEdit",
          "group": "navigation@-1",
          "when": "trace:isEditDiff"
        },
        {
          "command": "trace.predictLocations",
          "group": "navigation@-99",
          "when": "editorFocus && (!(trace:isEditDiff)) && trace:isLanguageSupported"
        },
        {
          "command": "trace.generateEdits",
          "group": "navigation@-98",
          "when": "editorFocus && (!(trace:isEditDiff)) && trace:isLanguageSupported"
        },
        {
          "command": "trace.inputMessage",
          "group": "navigation@-97",
          "when": "(!(trace:isEditDiff)) && trace:isLanguageSupported"
        },
        {
          "command": "trace.clearPrevEdits",
          "group": "navigation@-96",
          "when": "(!(trace:isEditDiff)) && trace:isLanguageSupported"
        }
      ],
      "view/title": [
        {
          "command": "trace.clearLocations",
          "when": "view == editLocations",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trace",
          "title": "TRACE",
          "icon": "$(edit)"
        }
      ]
    },
    "views": {
      "trace": [
        {
          "id": "editLocations",
          "name": "Suggested Edit Locations"
        },
        {
          "id": "Refactor",
          "name": "Suggested Code Actions"
        }
      ]
    },
    "keybindings": [
      {
        "command": "trace.predictLocations",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l"
      },
      {
        "command": "trace.generateEdits",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorFocus"
      }
    ]
  },
  "scripts": {
    "test": "node ./test/suite/test.js",
    "watch": "tsc --watch --allowJs -p tsconfig.json",
    "build": "tsc --build tsconfig.json",
    "package": "yarn build && yes | vsce package --no-yarn"
  },
  "devDependencies": {
    "@types/diff": "^5.0.8",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.16.9",
    "@types/vscode": "^1.78.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^8.57.0",
    "typescript": "~5.5.3"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "diff": "^5.1.0",
    "fast-fuzzy": "^1.12.0",
    "fuzzysort": "^3.0.2",
    "glob": "^10.3.10",
    "io-ts": "^2.2.21",
    "mocha": "^10.2.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-java": "^0.21.0",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.21.2",
    "ts-node": "^10.9.2",
    "vscode-languageserver": "^8.1.0"
  }
}
